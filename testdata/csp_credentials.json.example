{
  "comment": "Copy this file to csp_credentials.json and fill in real staging keys. Alternatively, set CSP_CREDENTIALS_JSON as an env var with the JSON contents. Keys are consumed after use — clean up orphaned VXCs between runs to free Azure port+vlan slots.",
  "azure_service_keys": [
    "REPLACE_WITH_AZURE_SERVICE_KEY"
  ],
  "google_pairing_keys": [
    "REPLACE_WITH_GCP_PAIRING_KEY/region/1"
  ]
}
